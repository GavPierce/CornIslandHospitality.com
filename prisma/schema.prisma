generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VolunteerType {
  SINGLE_BROTHER
  SINGLE_SISTER
  MARRIED_COUPLE
}

enum Language {
  EN
  ES
}

enum ShiftSlot {
  EVENING    // 5:00 pm – 12:30 am
  OVERNIGHT  // 12:30 am – 8:00 am
  MORNING    // 8:00 am – 12:30 pm (Sun & Mon only)
  AFTERNOON  // 12:30 pm – 5:00 pm (Sun & Mon only)
  LUNCH      // 12:00 pm – 1:00 pm (Tue–Sat only)
}

model House {
  id               String          @id @default(cuid())
  name             String
  address          String
  acceptedTypes    VolunteerType[] // e.g. [SINGLE_SISTER, MARRIED_COUPLE]
  owners           HouseOwner[]    // volunteers who co-own/host this house
  rooms            Room[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Room {
  id            String      @id @default(cuid())
  name          String      // e.g., "Master Bedroom", "Room 1"
  capacity      Int         // e.g., 2 beds
  houseId       String
  house         House       @relation(fields: [houseId], references: [id], onDelete: Cascade)
  assignments   Assignment[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Volunteer {
  id                     String        @id @default(cuid())
  name                   String
  email                  String?
  phone                  String?
  type                   VolunteerType
  language               Language?     // preferred language for WhatsApp reminders
  isWatchman             Boolean       @default(false) // also stands night-watch shifts
  isHospitality          Boolean       @default(false) // member of the hospitality welcome team
  assignments            Assignment[]  @relation("AssignmentVolunteer")
  hospitalityAssignments Assignment[]  @relation("HospitalityMember") // assignments where this volunteer is the hospitality contact
  shifts                 WatchmanShift[]
  ownedHouses            HouseOwner[]  // join rows where this volunteer is a house owner
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
}

// Many-to-many: a house can have multiple owners, a volunteer can own multiple houses
model HouseOwner {
  houseId     String
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([houseId, volunteerId])
  @@index([volunteerId])
}

model Assignment {
  id                    String     @id @default(cuid())
  volunteerId           String
  volunteer             Volunteer  @relation("AssignmentVolunteer", fields: [volunteerId], references: [id], onDelete: Cascade)
  roomId                String
  room                  Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  startDate             DateTime
  endDate               DateTime
  hospitalityMemberId   String?    // optional hospitality team member assigned to welcome this volunteer
  hospitalityMember     Volunteer? @relation("HospitalityMember", fields: [hospitalityMemberId], references: [id], onDelete: SetNull)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([roomId])
  @@index([volunteerId])
  @@index([hospitalityMemberId])
}

model WatchmanShift {
  id          String    @id @default(cuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  date        DateTime  // The calendar day (stored at 00:00 UTC)
  slot        ShiftSlot @default(EVENING)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([volunteerId, date, slot])
  @@index([date])
  @@index([volunteerId])
}

// ─── Passwordless auth (phone + WhatsApp OTP) ─────────────

enum IdentityType {
  WATCHMAN  // deprecated: retained for legacy sessions; new sessions always use VOLUNTEER
  VOLUNTEER
}

model AuthOtp {
  id         String    @id @default(cuid())
  phone      String    // normalized E.164 (e.g. +50588886666)
  codeHash   String    // sha256 hex of the 6-digit code
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model AuthSession {
  id           String       @id @default(cuid())
  token        String       @unique  // opaque random token stored in the cookie
  phone        String       // normalized E.164
  name         String       // display name captured at login
  identityType IdentityType
  identityId   String       // id of the linked Volunteer row
  isAdmin      Boolean      @default(false)
  expiresAt    DateTime
  lastSeenAt   DateTime     @default(now())
  createdAt    DateTime     @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ─── WhatsApp reminders ──────────────────────────────────

enum ReminderKind {
  WATCHMAN_SHIFT           // day-of reminder to the watchman
  VOLUNTEER_ARRIVAL        // day-of welcome to the volunteer
  VOLUNTEER_DEPARTURE      // day-of checkout reminder to the volunteer
  ADMIN_DAILY_DIGEST       // daily summary to each admin phone
  ASSIGNMENT_CONFIRMATION  // instant confirmation when a room is assigned
  HOSPITALITY_PAIRING      // instant notification to hospitality member when paired
  HOSPITALITY_CANCELLATION // notification to hospitality member when they are replaced
  HOSPITALITY_ARRIVAL      // day-of reminder to hospitality member when their volunteer arrives
  ASSIGNMENT_FAQ_MAP       // sent immediately after assignment confirmation with map and FAQ
}

/**
 * One row per (kind, recipient, reference) tuple that has been reminded.
 * The unique index is what prevents the scheduler from double-sending
 * if it runs more than once per day (e.g. after a redeploy). `referenceId`
 * is a shift id, an assignment id, or a date key (`YYYY-MM-DD`) for the
 * admin digest.
 */
model ReminderLog {
  id             String       @id @default(cuid())
  kind           ReminderKind
  recipientPhone String       // normalized E.164
  referenceId    String
  sentAt         DateTime     @default(now())

  @@unique([kind, recipientPhone, referenceId])
  @@index([sentAt])
}

// ─── App-wide settings ───────────────────────────────────
//
// Single-row-per-key key/value store for runtime feature flags that an
// admin can toggle without redeploying. Currently used for the
// reminders kill switch (`reminders.enabled`).

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
